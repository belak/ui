{
  "name": "@belak/ui",
  "version": "0.1.1",
  "description": "Opinionated Svelte 5 component library and design tokens.",
  "license": "MIT",
  "author": "Kaleb Elwert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/belak/ui.git"
  },
  "homepage": "https://github.com/belak/ui",
  "bugs": "https://github.com/belak/ui/issues",
  "keywords": [
    "svelte",
    "svelte5",
    "components",
    "ui",
    "design-tokens"
  ],
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "files": [
    "dist"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./util": {
      "types": "./dist/util/index.d.ts",
      "svelte": "./dist/util/index.js",
      "default": "./dist/util/index.js"
    },
    "./css": "./dist/css/index.css",
    "./tokens": "./dist/css/tokens.css",
    "./reset": "./dist/css/reset.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "package": "svelte-package -i src -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm run package"
  },
  "peerDependencies": {
    "@lucide/svelte": "^1",
    "svelte": "^5"
  },
  "peerDependenciesMeta": {
    "@lucide/svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^5",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "vite": "^6"
  }
}
